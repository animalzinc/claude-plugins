  },
  "metadata": {
    "description": "Official Animalz Claude Code plugins for content marketing workflows",
    "version": "2.0.0"
  },
  "plugins": [
    {
      "name": "structured-article-writer",
      "source": "./plugins/structured-article-writer",
      "description": "8-phase structured article writing process for thought leadership. Human fills the blank page — Claude enforces discipline through quality gates. Includes /write-rescue and /write-status companion commands.",
      "version": "1.0.0",
      "author": {
        "name": "Tim Metz @ Animalz",
        "url": "https://animalz.co"
      },
      "homepage": "https://github.com/animalzinc/claude-plugins",
      "repository": "https://github.com/animalzinc/claude-plugins",
      "license": "MIT",
      "keywords": [
        "writing",
        "article",
        "thought-leadership",
        "editorial",
        "content-marketing",
        "structured-writing"
      ],
      "category": "marketing",
      "strict": false
    },
    {
      "name": "copywriting-coach",
      "source": "./plugins/copywriting-coach",
      "description": "Structured 7-phase copywriting process for landing pages, ads, emails, and taglines. Human writes, AI coaches through Harry Dry's Three Laws, Sullivan's craft principles, and Wiebe's Money Words.",
      "version": "1.0.1",
      "author": {
        "name": "Tim Metz @ Animalz",
        "url": "https://animalz.co"
      },
      "homepage": "https://github.com/animalzinc/claude-plugins",
      "repository": "https://github.com/animalzinc/claude-plugins",
      "license": "MIT",
      "keywords": [
        "copywriting",
        "landing-page",
        "advertising",
        "copy",
        "conversion",
        "marketing"
      ],
      "category": "marketing",
      "strict": false
    },
    {
      "name": "blog-style-guide-creator",
      "source": "./plugins/blog-style-guide-creator",
      "description": "AI-powered editorial style guide generation from blog content and article compliance review system",
      "version": "1.1.0",
      "author": {
        "name": "Tim Metz @ Animalz",
        "url": "https://animalz.co"
      },
      "homepage": "https://github.com/animalzinc/claude-plugins",
      "repository": "https://github.com/animalzinc/claude-plugins",
      "license": "MIT",
      "keywords": [
        "content-marketing",
        "style-guide",
        "editorial",
        "blog",
        "content-review",
        "writing",
        "editorial-voice"
      ],
      "category": "marketing",
      "strict": false,
      "commands": [
        "./commands/generate-style-guide.md",
        "./commands/style-check.md",
        "./commands/batch-review.md"
      ],
      "agents": [
        "./agents/style-guide-generator.md",
        "./agents/voice-tone-agent.md",
        "./agents/grammar-usage-agent.md",
        "./agents/punctuation-agent.md",
        "./agents/formatting-agent.md",
        "./agents/technical-standards-agent.md",
        "./agents/content-patterns-agent.md",
        "./agents/industry-terms-agent.md",
        "./agents/quick-reference-agent.md"
      ]
    },
    {
      "name": "design-reference",
      "source": "./plugins/design-reference",
      "description": "Iterative design research process: brief, reference collection, feedback, principles, prototype, approval. Builds visual direction from stakeholder input before any prototyping begins.",
      "version": "1.0.0",
      "author": {
        "name": "Tim Metz @ Animalz",
        "url": "https://animalz.co"
      },
      "homepage": "https://github.com/animalzinc/claude-plugins",
